# POSTGRES
POSTGRES_USER=pgadmin
POSTGRES_PASSWORD=pgadmin123
POSTGRES_DB=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# DATABASES ESPECÍFICOS
HAPI_DB=hapi
HAPI_DB_USER=hapi_user
HAPI_DB_PASS=hapi_pass

SUPERSET_DB=superset
SUPERSET_DB_USER=superset_user
SUPERSET_DB_PASS=superset_pass

# HAPI
HAPI_HTTP_PORT=8080
# Memória Java restrita para 4GB total (ajuste conforme necessidade)
HAPI_JAVA_OPTS=-Xms512m -Xmx1500m -XX:+UseG1GC -Djava.net.preferIPv4Stack=true

# FASTAPI
FASTAPI_PORT=8000
API_TOKEN=troque-essa-chave

# SUPERSET
SUPERSET_PORT=8088
SUPERSET_SECRET_KEY=change-this-long-and-random
SUPERSET_ADMIN_USERNAME=admin
SUPERSET_ADMIN_PASSWORD=admin123
SUPERSET_ADMIN_EMAIL=admin@example.com
